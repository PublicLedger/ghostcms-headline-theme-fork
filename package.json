{
  "_comment_identity": "Fork-specific identity fields",
  "name": "publicledger-headline-fork",
  "description": "Fork of Ghost Foundation's Headline theme for The Public Ledger project",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=24.0.0",
    "ghost": ">=6.0.0"
  },
  "license": "MIT",
  "_comment_author": "REQUIRED: Must preserve Ghost Foundation as author per MIT license",
  "author": {
    "name": "Ghost Foundation",
    "email": "hello@ghost.org",
    "url": "https://ghost.org"
  },
  "_comment_contributors": "Fork maintainer attribution goes here",
  "contributors": [
    {
      "name": "Gasworks Data",
      "email": "info@gasworksdata.com",
      "url": "https://gasworksdata.com"
    }
  ],
  "_comment_repository": "Fork-specific repository URL",
  "repository": {
    "type": "git",
    "url": "https://github.com/PublicLedger/ghostcms-headline-theme-fork.git"
  },
  "keywords": ["ghost", "theme", "ghost-theme", "fork"],
  "docs": "https://headline.ghost.io/about/",
  "_comment_config": "UPSTREAM: Ghost theme configuration - do not modify unless syncing from TryGhost/Headline",
  "config": {
    "posts_per_page": 7,
    "image_sizes": {
      "xs": {
        "width": 150
      },
      "s": {
        "width": 300
      },
      "m": {
        "width": 720
      },
      "l": {
        "width": 960
      },
      "xl": {
        "width": 1200
      },
      "xxl": {
        "width": 2000
      }
    },
    "card_assets": true,
    "custom": {
      "navigation_layout": {
        "type": "select",
        "options": ["Logo on the left", "Logo in the middle", "Stacked"],
        "default": "Logo on the left"
      },
      "header_style": {
        "type": "select",
        "options": ["Light", "Accent color", "Dark"],
        "default": "Light"
      },
      "title_font": {
        "type": "select",
        "options": ["Modern sans-serif", "Elegant serif"],
        "default": "Elegant serif"
      },
      "body_font": {
        "type": "select",
        "options": ["Modern sans-serif", "Elegant serif"],
        "default": "Modern sans-serif"
      },
      "white_publication_logo_for_transparent_header": {
        "type": "image"
      },
      "email_signup_text": {
        "type": "text",
        "default": "Follow The Public Ledger. Sign up now to get access once we launch."
      },
      "footer_text": {
        "type": "text"
      },
      "enter_tag_slugs_for_primary_sections": {
        "type": "text",
        "group": "homepage"
      },
      "enter_tag_slugs_for_secondary_sections": {
        "type": "text",
        "group": "homepage"
      }
    }
  },
  "_comment_scripts": "UPSTREAM scripts: dev, test, zip. FORK additions: validate:fork, ghost:*, lint*",
  "scripts": {
    "dev": "gulp",
    "test": "gscan .",
    "zip": "gulp zip",
    "validate": "gscan . --verbose",
    "validate:fork": "bash scripts/validate-fork.sh",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "ghost:dev": "echo 'Ghost dev instance available at http://localhost:3001'",
    "ghost:prod": "docker compose --profile production up -d ghost-prod db",
    "ghost:stop": "docker compose down",
    "ghost:logs": "docker compose logs -f ghost-dev",
    "ghost:restart": "docker compose restart ghost-dev"
  },
  "_comment_packageManager": "Pinned to match TryGhost/Headline upstream (easier sync)",
  "packageManager": "pnpm@11.9.0",
  "_comment_devDependencies": "UPSTREAM: All dependencies from TryGhost/Headline - do not modify",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@gitkumi/prettier-plugin-handlebars": "^1.5.0",
    "@tryghost/shared-theme-assets": "2.7.1",
    "@tryghost/theme-translations": "^0.0.9",
    "@typescript-eslint/parser": "^8.62.0",
    "autoprefixer": "10.5.0",
    "beeper": "2.1.0",
    "cssnano": "8.0.2",
    "eslint": "^10.6.0",
    "eslint-plugin-jsdoc": "^63.0.10",
    "globals": "^17.7.0",
    "gscan": "6.4.1",
    "gulp": "5.0.1",
    "gulp-concat": "2.6.1",
    "gulp-livereload": "4.0.2",
    "gulp-postcss": "10.0.0",
    "gulp-uglify": "3.0.2",
    "gulp-zip": "5.1.0",
    "ordered-read-streams": "2.0.0",
    "postcss": "8.5.15",
    "postcss-easy-import": "4.0.0",
    "prettier": "^3.4.2",
    "pump": "3.0.4"
  }
}
