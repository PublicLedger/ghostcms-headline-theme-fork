# EditorConfig helps maintain consistent coding styles across different editors
# https://editorconfig.org

root = true

# Universal settings
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2
max_line_length = 80

# Markdown files - preserve trailing spaces (for line breaks)
[*.md]
trim_trailing_whitespace = false
max_line_length = 80

# YAML files
[*.{yml,yaml}]
indent_size = 2
max_line_length = 80

# Handlebars templates (Ghost)
[*.hbs]
indent_size = 2
max_line_length = 100

# HTML/CSS/JS files
[*.{html,css,js,json}]
indent_size = 2
max_line_length = 80

# Makefiles require tabs
[Makefile]
indent_style = tab
max_line_length = 80
